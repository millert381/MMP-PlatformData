###############################################################################
# Core Settings
###############################################################################

# Auto-detect text files and normalize to LF in repo
* text=auto

###############################################################################
# Explicit Text Files (force LF for Docker/Linux compatibility)
###############################################################################

*.sh        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.conf      text eol=lf
*.md        text eol=lf

###############################################################################
# Windows-specific (if ever added)
###############################################################################

*.ps1       text eol=crlf
*.bat       text eol=crlf

###############################################################################
# Binary Files (never modify)
###############################################################################

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.zip       binary

###############################################################################
# SQL Diff Improvements (optional but nice)
###############################################################################

*.sql diff

###############################################################################
# YAML Diff Improvements
###############################################################################

*.yml diff
*.yaml diff

###############################################################################
# Docker Files
###############################################################################

Dockerfile  text eol=lf
*.dockerfile text eol=lf